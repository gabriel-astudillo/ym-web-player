@startuml AYM_Player_Sequence
autonumber
skinparam BoxPadding 10
skinparam ParticipantPadding 10

actor Usuario
box "Frontend (Hilo Principal - UI)" #FFFDEB
    participant "AYM_PlayerView\n(aym-player-view.js)" as View
    participant "AYM_Player\n(aym-player.js)" as Controller
    participant "AYM_PlayerModel\n(aym-player-model.js)" as Model
    participant "ChiptuneFile\n(ChiptuneFile.js)" as Chiptune
end box

box "Audio (Hilo Web Audio)" #E8F5E9
    participant "AudioContext" as AudioCtx
    participant "AYM_PlayerProcessor\n(aym-player-processor.js)" as Processor
    participant "AYM_Emulator\n(aym-emulator.js)" as Emulator
end box

== 1. Inicialización y Encendido (Power On) ==

Usuario -> View: Clic en botón "Power"
activate View
View -> Controller: onClickPower()
activate Controller

Controller -> Model: isNotPowered()
activate Model
Model --> Controller: true
deactivate Model

Controller -> Model: powerOn()
activate Model

Model -> AudioCtx: new AudioContext()

activate AudioCtx
AudioCtx --> Model: Thread cargado
deactivate AudioCtx

Model -> AudioCtx: audioWorklet.addModule('aym-player-processor.js')
activate AudioCtx
AudioCtx --> Model: Módulo cargado
deactivate AudioCtx

Model -> Model: createWorklet()
note over Model
  Crea AudioWorkletNode
  con 4 salidas discretas:
  - Output 0: Mezcla Estéreo
  - Output 1, 2, 3: Canal A, B, C puro
end note

Model -> Model: createAnalyser()
note over Model
  Crea waAnalyser y conectores
  waAnalyserCh0, Ch1, Ch2
  asociados a las salidas 1, 2, 3 del Worklet
end note

Model -> Model: createGain()
Model -> Processor: new PlayerProcesor() (thread)
activate Processor
Processor --> Model: Thread cargado
deactivate Processor

Model --> Controller: Contexto y nodos listos
deactivate Model

Controller -> View: powerOn()
View -> View: bind()
View -> Controller: startAnalyse()
Controller -> View: renderFFT()
note over View
  Inicia bucles asíncronos en tiempo real:
  - fftRender()
  - fftRenderChannel0()
  - fftRenderChannel1()
  - fftRenderChannel2()
end note

Controller -> Model: sendRequestTrackList()
activate Model
Model -> Processor: postMessage('RequestTrackList')
deactivate Model
activate Processor
Processor --> Model: postMessage('TrackList', trackNames)
deactivate Processor

activate Model
Model -> Controller: recvMessage('TrackList')
deactivate Model
Controller -> View: populateSelector(trackList)

View --> Usuario: Interfaz encendida y lista de pistas cargada
deactivate View
deactivate Controller

== 2. Reproducción de Archivo Externo (.ym) ==

Usuario -> View: Selecciona archivo local o remoto (.ym)
activate View
View -> Controller: onFileSelected(file) / onHyperlinkFileSelected(url)
activate Controller

Controller -> Chiptune: new ChiptuneFile()
Controller -> Chiptune: loadFile(file)
activate Chiptune
Chiptune --> Controller: Datos cargados y descomprimidos (LHA)
deactivate Chiptune

Controller -> Chiptune: getData()
activate Chiptune
Chiptune --> Controller: [songData, nFrames, interleaved]
deactivate Chiptune

Controller -> Controller: Formatea estructura (this.externalMusic)
Controller -> Model: sendExternalTrack(musicData)
activate Model
Model -> Processor: postMessage('PlayExternal', musicData)
deactivate Model
deactivate Controller
deactivate View

activate Processor
Processor -> Emulator: set_type_ym()
note over Processor
  Configura variables internas:
  - music_index = 0
  - music_count = nFrames
  - music_clock = 50Hz
end note

== 3. Bucle de Audio y Renderizado Visual (Ciclo Continuo) ==

loop Cada callback de process() (Web Audio API)
    Processor -> Emulator: clock()
    activate Emulator
    Emulator --> Processor: muestras de canal_a, channel_b, channel_c
    deactivate Emulator
    
    Processor -> Processor: mixStereo(outputs[0][0], outputs[0][1])
    note over Processor
       Vuelca channel_a, channel_b, channel_c
       puros en outputs[1], outputs[2], outputs[3]
    end note
end

loop Cada Frame de Animación (requestAnimationFrame)
    View -> Model: waAnalyserCh0.getByteTimeDomainData(fftData)
    activate Model
    Model --> View: fftData (Dominio del tiempo)[cite: 1]
    deactivate Model
    
    View -> View: Algoritmo de Estabilización (Trigger)
    View -> View: Centrado de onda y amplificación (zoomY)
    View -> View: Dibuja trazo continuo (lineTo) en canvasCh0
end

@enduml